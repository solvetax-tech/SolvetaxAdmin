# Evolution API — Sandbox Environment Variables
# Copy to .env and fill in values before running docker compose up.
# .env is gitignored. Never commit real secrets.
# Generate strong passwords: openssl rand -hex 32
#
# Full variable reference: docs/evolution-api/02-deployment.md §3
# SolveTax-specific decisions: docs/evolution-api/02-deployment.md §8

# ── SERVER ────────────────────────────────────────────────────────────────────
SERVER_TYPE=http                   # sandbox: no TLS; prod uses nginx for TLS termination
SERVER_PORT=8080                   # port the container listens on
SERVER_URL=http://localhost:8080   # sandbox: localhost; prod: public URL e.g. https://evo.solvetax.in
SERVER_NAME=evolution              # identifier shown in logs
SERVER_DISABLE_DOCS=false          # set true in prod to hide Swagger at /docs
SERVER_DISABLE_MANAGER=false       # set true in prod to disable built-in Manager UI at /manager

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# Sent as the "apikey" header on all requests. Use a strong random value.
AUTHENTICATION_API_KEY=CHANGE-ME-strong-random-api-key-min-32-chars
# Set false to prevent per-instance API keys appearing in GET /instance/fetchInstances responses
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# ── DATABASE (Postgres — matches the evolution_postgres container above) ───────
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=CHANGE-ME-strong-random-postgres-password
POSTGRES_DATABASE=evolution_db

DATABASE_PROVIDER=postgresql
# Must include ?schema=evolution_api — without it Prisma defaults to public schema (see doc 02 §6)
DATABASE_CONNECTION_URI=postgresql://evolution:CHANGE-ME-strong-random-postgres-password@evolution_postgres:5432/evolution_db?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

# Persist instance metadata (required)
DATABASE_SAVE_DATA_INSTANCE=true
# Delivery/read-receipt status updates (keep true)
DATABASE_SAVE_MESSAGE_UPDATE=true
# Phase 0: disable high-I/O stores; no client data in sandbox (doc 08 Phase 0 config)
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_IS_ON_WHATSAPP=true
DATABASE_SAVE_IS_ON_WHATSAPP_DAYS=7
DATABASE_DELETE_MESSAGE=true

# ── CACHE / REDIS ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE-ME-strong-random-redis-password

CACHE_REDIS_ENABLED=true
# DB index 6 by convention; prefix namespaces all keys
CACHE_REDIS_URI=redis://:CHANGE-ME-strong-random-redis-password@evolution_redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_TTL=604800             # 7 days in seconds
# false = single container (sandbox); set true only for horizontal scaling (multiple API pods)
CACHE_REDIS_SAVE_INSTANCES=false

# QR/pairing workaround: if QR codes fail silently or pairing completes but no messages
# arrive, try CACHE_REDIS_ENABLED=false + CACHE_LOCAL_ENABLED=true (doc 02 §3 CACHE_LOCAL_*)
CACHE_LOCAL_ENABLED=false
CACHE_LOCAL_TTL=86400

# ── WEBHOOK (Phase 2 — leave commented-out for Phase 0 sandbox) ───────────────
# WEBHOOK_GLOBAL_ENABLED=false
# WEBHOOK_GLOBAL_URL=https://solvetax-admin-prod.azurewebsites.net/api/v1/whatsapp/webhook
# WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
# Retry config (set now to avoid webhook flood bug — GitHub #1325)
WEBHOOK_REQUEST_TIMEOUT_MS=30000
WEBHOOK_RETRY_MAX_ATTEMPTS=3
WEBHOOK_RETRY_INITIAL_DELAY_SECONDS=5
WEBHOOK_RETRY_USE_EXPONENTIAL_BACKOFF=true
WEBHOOK_RETRY_MAX_DELAY_SECONDS=60
WEBHOOK_RETRY_JITTER_FACTOR=0.2
WEBHOOK_RETRY_NON_RETRYABLE_STATUS_CODES=400,401,403,404,422

# ── CONFIG_SESSION_PHONE ──────────────────────────────────────────────────────
# Name shown in WhatsApp "Linked Devices" list on the connected phone
CONFIG_SESSION_PHONE_CLIENT=SolveTax
# Browser identity declared to WhatsApp Web
CONFIG_SESSION_PHONE_NAME=Chrome
#
# WARNING — CONFIG_SESSION_PHONE_VERSION: do NOT set this variable.
# The WA Web version is determined by the pinned Baileys dependency in v2.3.7.
# Setting a stale version (e.g. 2.3000.1015901307 from old Coolify templates) causes
# silent QR generation failure or broken pairing. If QR fails, upgrade the image instead
# of patching this value. See docs/evolution-api/02-deployment.md §3 CONFIG_SESSION_PHONE_*.

# ── INSTANCE MANAGEMENT ───────────────────────────────────────────────────────
# false = never auto-delete stale instances; set a number (minutes) to prune disconnected sessions
DEL_INSTANCE=false
DEL_TEMP_INSTANCES=true

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=ERROR,WARN,INFO          # reduce from the verbose default for sandbox clarity
LOG_COLOR=true
LOG_BAILEYS=error                  # Baileys internal log level

# ── LANGUAGE ─────────────────────────────────────────────────────────────────
LANGUAGE=en                        # response language; also governs Whisper transcription

# ── TELEMETRY ─────────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=false            # opt out of anonymous usage telemetry to Evolution Foundation

# ── WEBSOCKET (disabled for sandbox; enable only if frontend connects directly) ─
WEBSOCKET_ENABLED=false
WEBSOCKET_GLOBAL_EVENTS=false

# ── QUEUE / MESSAGE BROKERS (not needed — leave all false) ───────────────────
# RABBITMQ_ENABLED=false
# SQS_ENABLED=false
# KAFKA_ENABLED=false
# NATS_ENABLED=false

# ── S3 / MEDIA (not needed for sandbox; media arrives as base64 in webhooks) ──
# S3_ENABLED=false
