# Copy to .env on the Azure VM (never commit .env)
# cp .env.example .env && nano .env

# ---- App ----
HOST=0.0.0.0
PORT=8000
WORKERS=1
RUN_SCHEDULER=true

# ---- Docker / CI-CD (server pulls from GHCR; tag chosen by branch: dev | prod) ----
GHCR_IMAGE=ghcr.io/solvetax-tech/solvetaxadmin
# At runtime deploy sets: API_IMAGE=${GHCR_IMAGE}:dev  or  :prod
# API_IMAGE=ghcr.io/solvetax-tech/solvetaxadmin:prod

# ---- Frontend build-time (CI secrets; empty = same origin in prod) ----
VITE_API_URL=
VITE_PUBLIC_API_KEY=

# ---- Production nginx + SSL (docker-compose.prod.yml) ----
# DNS A record: DOMAIN -> VM public IP before running init-letsencrypt.sh
DOMAIN=app.yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com
# CERT_NAME=app.yourdomain.com
# CERTBOT_STAGING=1
# CERTBOT_EXTRA_DOMAINS=-d www.yourdomain.com
DB_SCHEMA=solvetax
DB_APP_NAME=slovetax-api
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30

# ---- PostgreSQL (Azure Database for PostgreSQL) ----
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=your_admin_user
DB_PASSWORD=your_db_password

# ---- Redis (Azure Cache for Redis) ----
REDIS_HOST=your-redis.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_access_key
REDIS_CONNECT_TIMEOUT_SEC=2
REDIS_COOLDOWN_SEC=15

# ---- Auth ----
JWT_SECRET=change_me_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
PUBLIC_API_KEY=change_me_public_api_key

# ---- Azure Blob ----
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=gst-documents
AZURE_STORAGE_CONTAINER1=business-images
AZURE_SAS_EXPIRY_MINUTES=15

# ---- SMTP (OTP / email) ----
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=you@example.com
SMTP_PASSWORD=your_app_password
OTP_EXPIRY_MINUTES=10

# ---- Azure OpenAI (optional) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_TIMEOUT_SEC=45

# ---- MSG91 (optional) ----
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_COUNTRY_CODE=91
MSG91_TIMEOUT_SECONDS=10
